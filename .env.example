# Adore Salon AI Receptionist — environment variables.
# Copy to .env and fill in. NEVER commit the real .env (it's gitignored).

# --- AI (required for the receptionist brain, phone + demo) -----------------
ANTHROPIC_API_KEY=

# --- Telephony (required only to run the live phone server, `npm start`) -----
DEEPGRAM_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# --- Booker / Mindbody API (required for real services + booking) ------------
# Defaults to the staging host if unset.
BOOKER_BASE_URL=https://api-staging.booker.com
BOOKER_LOCATION_ID=
BOOKER_CLIENT_ID=
BOOKER_CLIENT_SECRET=
BOOKER_SUBSCRIPTION_KEY=
# Merchant API (caller lookup, cancel, book-as-business) — needs both:
BOOKER_MERCHANT_SUBSCRIPTION_KEY=
BOOKER_PERSONAL_ACCESS_TOKEN=
# Last-resort room fallback; the app now looks up a room per treatment.
BOOKER_DEFAULT_ROOM_ID=
BOOKER_DEFAULT_EMPLOYEE_ID=
